# ═══════════════════════════════════════════════════════════════
# GLX Partners — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# HOSTINGER SETUP:
#   Build command : pnpm install && pnpm build
#   Start command : node dist/index.js
#   Node version  : 20.x
#   After first deploy, run migrations once via SSH:
#     DATABASE_URL=<url> pnpm db:migrate

# ── Core ──
# REQUIRED: set to "production" on Hostinger
NODE_ENV=production
# PORT is assigned automatically by Hostinger — do NOT set it there
PORT=3000

# ── Security ──
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Database ──
# REQUIRED in production.
# Hostinger MySQL format: mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME
# (use "localhost" — the DB runs on the same server)
DATABASE_URL=

# ── Bootstrap Users ──
# These run on startup (both dev and production).
# Set BOOTSTRAP_ADMIN_EMAIL + BOOTSTRAP_ADMIN_PASSWORD to create the first admin account.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change_this_admin_password

# Demo/test users (format: email|password|plan|name — multiple entries separated by semicolons)
# Leave empty in production unless you want demo accounts created automatically.
BOOTSTRAP_DEMO_USERS=
BOOTSTRAP_TEST_CLIENT_EMAILS=
BOOTSTRAP_TEST_CLIENT_PASSWORD=
BOOTSTRAP_TEST_CLIENT_NAME=

# ── OAuth (GLX Portal) ──
# Deixe em branco para desativar OAuth e usar apenas login por email
OAUTH_SERVER_URL=
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=

# ── Forge API (geração de imagens/IA) ──
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Kommo CRM Integration ──
KOMMO_CLIENT_ID=
KOMMO_CLIENT_SECRET=
KOMMO_WEBHOOK_SECRET=

# ── Asaas Payments Integration ──
ASAAS_ACCESS_TOKEN=
ASAAS_WEBHOOK_TOKEN=
# Padrão: https://api.asaas.com/v3
ASAAS_API_BASE_URL=
ASAAS_USER_AGENT=

# ── Exchange Rate API ──
# Padrão: https://api.frankfurter.dev/v1/latest
EXCHANGE_RATE_API_BASE_URL=
# Tempo de cache em ms. Padrão: 1800000 (30min)
EXCHANGE_RATE_CACHE_TTL_MS=

# ── Notification Settings ──
VITE_TEST_NOTIFICATION_EMAILS=
